@startuml 05-components-api
title Component Diagram — API Server

skinparam rectangle {
  BackgroundColor #dae8fc
  BorderColor #6c8ebf
  FontSize 11
}
skinparam database {
  BackgroundColor #fff2cc
  BorderColor #d6b656
}

rectangle "API Server (Node.js + Express)" {
  rectangle "Users Router+Service\n[Express Router]\nRegistration, login, JWT" as users
  rectangle "Catalog Router+Service\n[Express Router]\nBook CRUD, search, cache" as catalog
  rectangle "Orders Router+Service\n[Express Router]\nCart, order lifecycle" as orders
  rectangle "Payment Router+Service\n[Express Router]\nStripe integration" as payment
  rectangle "Notifications Service\n[Bull Producer]\nEnqueues email jobs" as notif
  rectangle "Auth Middleware\n[Express Middleware]\nJWT validation" as auth
  rectangle "Error Handler\n[Express Middleware]\nCentralised errors" as errors
  rectangle "DB Client\n[node-postgres]\nShared connection pool" as dbclient
}

database "PostgreSQL" as db
database "Redis" as redis
rectangle "Stripe\n[External]" as stripe

users --> dbclient : "users schema"
catalog --> dbclient : "catalog schema"
catalog --> redis : "cache [TCP]"
orders --> dbclient : "orders schema"
orders --> notif : "enqueue email"
payment --> stripe : "Payment Intents [HTTPS]"
payment --> orders : "confirm on webhook"
notif --> redis : "push job [TCP]"
dbclient --> db : "SQL [TCP]"

@enduml
