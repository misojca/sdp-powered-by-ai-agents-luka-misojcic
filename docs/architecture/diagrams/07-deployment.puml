@startuml 07-deployment
title Deployment Diagram — Online Bookstore (AWS)

skinparam rectangle {
  BackgroundColor #dae8fc
  BorderColor #6c8ebf
  FontSize 11
}
skinparam database {
  BackgroundColor #fff2cc
  BorderColor #d6b656
}
skinparam actor {
  BackgroundColor #d5e8d4
  BorderColor #82b366
}
skinparam node {
  BackgroundColor #f8cecc
  BorderColor #b85450
}

actor "Customer" as customer

rectangle "AWS" {
  rectangle "CloudFront + S3\n[CDN]\nServes React SPA" as cdn
  rectangle "ALB\n[Load Balancer]\nTLS termination" as alb

  node "ECS Fargate" {
    rectangle "API Server\n[Node.js + Express]" as api
    rectangle "Notification Worker\n[Node.js + Bull]" as worker
  }

  database "RDS PostgreSQL\n[PostgreSQL 16]\nMulti-AZ" as rds
  database "ElastiCache\n[Redis 7]\nCache + queue" as elasticache
  rectangle "S3 (images)\n[AWS S3]" as s3images
  rectangle "Secrets Manager\n[AWS]" as secrets
}

rectangle "Stripe\n[External]" as stripe
rectangle "SendGrid\n[External]" as sendgrid

customer --> cdn : "Loads SPA [HTTPS]"
customer --> alb : "API requests [HTTPS]"
alb --> api : "Forwards [HTTP]"
api --> rds : "Reads/writes [TCP]"
api --> elasticache : "Cache + enqueue [TCP]"
api --> s3images : "Images [HTTPS]"
api --> stripe : "Payment Intents [HTTPS]"
api --> secrets : "Fetch secrets [HTTPS]"
worker --> elasticache : "Consume jobs [TCP]"
worker --> sendgrid : "Send emails [HTTPS]"
stripe --> alb : "Webhooks [HTTPS]"

@enduml
